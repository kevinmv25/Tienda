<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="453.0" prefWidth="530.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.controllers.AgregarController">
   <children>
      <HBox prefHeight="47.0" prefWidth="530.0" style="-fx-background-color: gray;">
         <children>
            <Label text="Agregar producto" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="17.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </Label>
         </children>
      </HBox>
      <HBox alignment="TOP_CENTER" layoutY="46.0" prefHeight="346.0" prefWidth="530.0" spacing="40.0">
         <children>
            <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" minWidth="200.0" prefHeight="262.0" prefWidth="226.0" spacing="10.0" style="-fx-background-color: #D8BFD8;">
               <children>
                  <Label alignment="CENTER" prefHeight="18.0" prefWidth="317.0" text="Nombre del producto" />
                  <TextField fx:id="txtNombre" prefHeight="26.0" prefWidth="202.0" promptText="Ej. Servilletas" />
                  <Label alignment="CENTER" prefHeight="18.0" prefWidth="317.0" text="Precio" />
                  <TextField fx:id="txtPrecio" promptText="Ej. 22.30" />
                  <Label alignment="CENTER" layoutX="30.0" layoutY="63.0" prefHeight="18.0" prefWidth="317.0" text="Categoria" />
                  <ComboBox fx:id="cbCategoria" prefWidth="150.0" style="-fx-border-color: #9370DB; -fx-border-radius: 5;" />
                  <DatePicker fx:id="dpCaducidad" promptText="Selecciona fecha" />
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
            <VBox alignment="TOP_CENTER" prefHeight="262.0" prefWidth="230.0" spacing="20.0" style="-fx-background-color: #E6E6FA;">
               <children>
                  <Button fx:id="btnCargarImagen" mnemonicParsing="false" onAction="#seleccionarArchivo" style="-fx-background-color: #b3b7d7;" text="Seleccionar archivo..." textFill="WHITE" />
                  <ImageView fx:id="imgPreview" fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
                  <Label alignment="CENTER" prefHeight="18.0" prefWidth="317.0" text="Imagen del producto" />
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </HBox>
      <HBox alignment="CENTER" layoutY="394.0" prefHeight="58.0" prefWidth="530.0" spacing="20.0" style="-fx-background-color: #fae8e8;">
         <children>
            <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#guardarEnBaseDeDatos" style="-fx-background-color: #f4c3d0;" text="Guardar producto" />
            <Button fx:id="btnRegresar" mnemonicParsing="false" onAction="#regresarInventario" style="-fx-background-color: #f4c3d0;" text="Regresar" />
         </children>
      </HBox>
   </children>
</AnchorPane>
